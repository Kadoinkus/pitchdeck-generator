{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"moduleResolution": "bundler",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"allowJs": true,
		"checkJs": false,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/client/**/*"]
}
