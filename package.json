{
	"name": "slide-deck-generator",
	"version": "1.0.0",
	"description": "Automatic client slide deck generator built with Node.js, Express, and PptxGenJS.",
	"keywords": [
		"powerpoint",
		"slides",
		"generator",
		"pptx",
		"express"
	],
	"license": "MIT",
	"type": "module",
	"scripts": {
		"bd": "vite build",
		"dev": "vite",
		"don't redefine commands, or I rape your mother": "",
		"fmt": "dprint fmt",
		"lint": "biome lint --write",
		"prestart": "bun bd",
		"start": "vite preview",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"pptxgenjs": "^4.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "^7.0.0-dev.20260323.1",
		"dprint": "^0.53.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.2",
		"vite-svg-to-ico": "^2.0.1"
	},
	"packageManager": "bun@1.3.11"
}
