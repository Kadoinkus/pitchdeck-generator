{
	"name": "slide-deck-generator",
	"version": "1.0.0",
	"description": "Automatic client slide deck generator built with Node.js, Express, and PptxGenJS.",
	"keywords": [
		"powerpoint",
		"slides",
		"generator",
		"pptx",
		"express"
	],
	"license": "MIT",
	"type": "module",
	"scripts": {
		"build": "vite build",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"dev": "vite dev",
		"fmt": "dprint fmt",
		"lint": "eslint .",
		"preview": "vite preview",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"test:unit": "vitest",
		"typecheck": "tsgo --noEmit"
	},
	"dependencies": {
		"pptxgenjs": "^4.0.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "^7.0.0-dev.20260324.1",
		"@vitest/browser-playwright": "^4.1.0",
		"dprint": "^0.53.0",
		"eslint": "^10.1.0",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"jiti": "^2.6.1",
		"playwright": "^1.58.2",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.5",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.2",
		"vitest": "^4.1.0",
		"vitest-browser-svelte": "^2.0.2"
	},
	"packageManager": "bun@1.3.11",
	"devEngines": {
		"packageManager": {
			"name": "bun"
		}
	}
}
