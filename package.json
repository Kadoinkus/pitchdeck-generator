{
	"name": "slide-deck-generator",
	"version": "1.0.0",
	"description": "Automatic client slide deck generator built with Node.js, Express, and PptxGenJS.",
	"main": "src/server.js",
	"type": "module",
	"scripts": {
		"dev": "bun --hot src/server.js",
		"start": "node src/server.js",
		"typecheck": "tsgo --noEmit",
		"typecheck:legacy": "tsc --noEmit",
		"lint": "biome check --write",
		"format": "biome format --write"
	},
	"keywords": [
		"powerpoint",
		"slides",
		"generator",
		"pptx",
		"express"
	],
	"license": "MIT",
	"dependencies": {
		"cors": "^2.8.5",
		"express": "^4.19.2",
		"pptxgenjs": "^3.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "7.0.0-dev.20260323.1",
		"typescript": "^6"
	},
	"packageManager": "pnpm@10.12.4"
}
