{
	"name": "slide-deck-generator",
	"version": "1.0.0",
	"description": "Automatic client slide deck generator built with Node.js, Express, and PptxGenJS.",
	"main": "dist/server/server.js",
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/server.ts",
		"build": "vite build && tsc -p tsconfig.server.json",
		"start": "node dist/server/server.js",
		"typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.server.json --noEmit",
		"typecheck:legacy": "tsc -p tsconfig.server.json --noEmit",
		"lint": "biome check --write",
		"format": "biome format --write"
	},
	"keywords": [
		"powerpoint",
		"slides",
		"generator",
		"pptx",
		"express"
	],
	"license": "MIT",
	"dependencies": {
		"cors": "^2.8.5",
		"express": "^4.19.2",
		"pptxgenjs": "^3.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "7.0.0-dev.20260323.1",
		"tsx": "^4.21.0",
		"typescript": "^6",
		"vite": "^8.0.2"
	},
	"packageManager": "pnpm@10.12.4"
}
