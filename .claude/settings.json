{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"env": {
		"BASH_MAX_OUTPUT_LENGTH": "100000",
		"MAX_MCP_OUTPUT_TOKENS": "100000",
		"CLAUDECODE": "1",
		"GIT_PAGER": "",
		"CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
		"CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
		"CLAUDE_CODE_ADDITIONAL_DIRECTORIES_CLAUDE_MD": "1",
		"CLAUDE_CODE_SHELL": "bash"
	},
	"permissions": {
		"allow": [
			"Bash(bun lint:*)",
			"Bash(bun type-check:*)",
			"Bash(bun typecheck:)",
			"Bash(unzip:*)",
			"Bash(bunx:*)",
			"mcp__context7",
			"mcp__git__git_branch",
			"mcp__git__git_create_branch",
			"mcp__git__git_diff",
			"mcp__git__git_diff_staged",
			"mcp__git__git_diff_unstaged",
			"mcp__git__git_init",
			"mcp__git__git_log",
			"mcp__git__git_show",
			"mcp__git__git_status",
			"mcp__morphllm-fast-apply",
			"mcp__playwright",
			"mcp__sequential",
			"mcp__sequential-thinking"
		],
		"deny": [
			"Read(./.env)",
			"Read(./.env.*)",
			"Read(./build)",
			"Read(./config/credentials.json)",
			"Read(./secrets/**)",
			"mcp__git__git_add"
		],
		"ask": [],
		"defaultMode": "bypassPermissions"
	},
	"enableAllProjectMcpServers": true,
	"hooks": {
		"PostToolUse": [{
			"matcher": "Edit|Write",
			"hooks": [{
				"type": "command",
				"command": "bash -c 'FILE=$(jq -r .tool_input.file_path); [[ -f \"$FILE\" ]] && dprint fmt \"$FILE\" 2>/dev/null; exit 0'",
				"timeout": 10,
				"statusMessage": "dprint fmt"
			}]
		}]
	},
	"statusLine": { "type": "command", "command": "bunx ccstatusline@latest" },
	"attribution": { "commit": "", "pr": "" },
	"enabledPlugins": {
		"superpowers@claude-plugins-official": true,
		"typescript-lsp@claude-plugins-official": true,
		"playwright@claude-plugins-official": true,
		"pr-review-toolkit@claude-plugins-official": true,
		"claude-md-management@claude-plugins-official": true,
		"claude-code-setup@claude-plugins-official": true,
		"hookify@claude-plugins-official": true,
		"learning-output-style@claude-plugins-official": true,
		"frontend-design@claude-code-plugins": true,
		"svelte@svelte": true
	},
	"alwaysThinkingEnabled": true,
	"effortLevel": "high",
	"autoUpdatesChannel": "latest",
	"skipDangerousModePermissionPrompt": true
}
